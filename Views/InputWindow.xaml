<Window x:Class="JuanNotTheHuman.Spending.Views.InputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JuanNotTheHuman.Spending.Views" xmlns:viewmodels="clr-namespace:JuanNotTheHuman.Spending.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="450" Width="800">
    <Window.DataContext>
        <viewmodels:InputWindowViewModel/>
    </Window.DataContext>
    <StackPanel>
        <TextBlock Text="{Binding Title}" Margin="10" FontSize="15" FontWeight="Bold" TextAlignment="Center"/>
        <TextBlock Text="{Binding Description}" Margin="5" TextAlignment="Center"/>
        <TextBox Text="{Binding Input}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="150" Margin="5"/>
        <DockPanel HorizontalAlignment="Center">
            <Button Content="Confirm" HorizontalAlignment="Center" Command="{Binding SubmitCommand}" Margin="5"/>
            <Button Content="Cancel" HorizontalAlignment="Center" Command="{Binding CancelCommand}" Margin="5"/>
        </DockPanel>
    </StackPanel>
</Window>
